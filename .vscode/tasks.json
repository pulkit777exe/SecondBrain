{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "dev",
        "panel": "dedicated",
        "reveal": "never"
      }
    },
    {
      "label": "frontend: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "dev",
        "panel": "dedicated",
        "reveal": "never"
      }
    },
    {
      "label": "dev",
      "dependsOn": ["backend: dev", "frontend: dev"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "group": "dev",
        "panel": "shared",
        "reveal": "never"
      }
    },
    {
      "label": "backend: build",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": "$tsc"
    },
    {
      "label": "frontend: build",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    },
    {
      "label": "build: all",
      "dependsOn": ["backend: build", "frontend: build"],
      "group": "build"
    }
  ]
}
